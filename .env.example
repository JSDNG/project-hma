# --- HMA Profile Sync API configuration ---

# Local HideMyAcc REST API base
HMA_LOCAL_API_BASE=http://127.0.0.1:2268

# n8n webhook base. The service appends /api/hma-profiles/sync automatically.
HMA_PROFILES_SYNC_URL=https://n8n.supover.com/webhook

# Required for non-dry-run /sync calls. The service refuses to forward without it.
# This is the OUTBOUND key sent as X-Api-Key to the downstream n8n webhook.
HMA_API_KEY=

# Required for ALL inbound requests to this service. Every caller must send
# this value as `x-api-key`. If unset, the service rejects every request with
# HTTP 500 (fail-closed). Generate a long random string, e.g.:
#   python -c "import secrets; print(secrets.token_hex(32))"
HMA_PROFILE_SYNC_API_KEY=

# HTTP client timeout, in seconds
HMA_HTTP_TIMEOUT=30

# Logger level: DEBUG, INFO, WARNING, ERROR
HMA_LOG_LEVEL=INFO
