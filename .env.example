# --- HMA Profile API configuration ---

# Local HideMyAcc REST API base
HMA_LOCAL_API_BASE=http://127.0.0.1:2268

# Required for ALL inbound requests to this service. Every caller must send
# this value as `x-api-key`. If unset, the service rejects every request with
# HTTP 500 (fail-closed). Generate a long random string, e.g.:
#   python -c "import secrets; print(secrets.token_hex(32))"
HMA_PROFILE_SYNC_API_KEY=

# HTTP client timeout, in seconds
HMA_HTTP_TIMEOUT=60

# Logger level: DEBUG, INFO, WARNING, ERROR
HMA_LOG_LEVEL=INFO

# --- Supover sync (scripts/sync_to_supover.py, scheduled twice daily) ---

# Remote endpoint that receives the raw HMA /profiles response.
SUPOVER_SYNC_URL=https://ai.supover.com/api/hma/profiles/sync

# x-api-key sent on every POST to SUPOVER_SYNC_URL. If unset, the runner
# script aborts before making any HTTP call (fail-closed).
SUPOVER_API_KEY=
